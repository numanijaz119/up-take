# ═══════════════════════════════════════════════════════════════════════════════
# Up-take — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://uptake:uptake_secret@localhost:5432/uptake

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Anthropic API (REQUIRED — get your key at https://console.anthropic.com) ──
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── LLM Model ─────────────────────────────────────────────────────────────────
# LLM_MODEL=claude-sonnet-4-20250514
# ANALYSIS_TEMPERATURE=0.2
# GENERATION_TEMPERATURE=0.7
# QUALITY_CHECK_TEMPERATURE=0.1

# ── Telegram Bot (optional — alerts are logged-only if not configured) ─────────
# Create a bot with @BotFather, then get your chat ID.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ── Pipeline Thresholds ───────────────────────────────────────────────────────
# MIN_OPPORTUNITY_SCORE=55        # 0-100: minimum score to generate a proposal
# MIN_PROPOSAL_QUALITY=7.0        # 0-10: regenerate proposal if below this
# MAX_JOB_AGE_HOURS=2             # drop jobs older than this
# PIPELINE_MAX_CONCURRENT_LLM=3   # max simultaneous Anthropic API calls

# ── Safety Limits ─────────────────────────────────────────────────────────────
# MAX_PROPOSALS_PER_DAY=12
# MAX_PROPOSALS_PER_HOUR=3
# MIN_SECONDS_BETWEEN_PROPOSALS=300
# ACTIVE_HOURS_START=8             # 0-23: earliest hour to approve proposals
# ACTIVE_HOURS_END=23              # 0-23: latest hour to approve proposals
# MAX_CONNECTS_PER_DAY=50
# MAX_PROPOSAL_WORD_OVERLAP=0.30   # max word overlap between recent proposals

# ── Extension Channel ─────────────────────────────────────────────────────────
# Generate a token: python -c "import secrets; print(secrets.token_urlsafe(32))"
EXTENSION_API_TOKEN=change-me-in-env
# EXTENSION_HEARTBEAT_TIMEOUT_SECONDS=300
# EXTENSION_PEAK_HOURS_TZ=America/New_York
# EXTENSION_PEAK_HOURS_START=9
# EXTENSION_PEAK_HOURS_END=22
# EXTENSION_NO_JOBS_ALERT_MINUTES=30
